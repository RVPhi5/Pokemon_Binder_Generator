# --- Data artifacts ---
# Ignore everything under data/ except the raw Kaggle CSV (already tracked).
# The raw images and preprocessed outputs are regenerated locally by the scripts
# in scripts/ and should not live in git.
data/*
!data/pokemon-cards.csv

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
.venv/
venv/
env/
.env

# --- OS / editor junk ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# --- Model / experiment artifacts ---
checkpoints/
runs/
wandb/
*.pt
*.pth
*.ckpt
*.npy
*.npz
